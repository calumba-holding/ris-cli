{
  "name": "urteil-watch",
  "version": "1.0.0",
  "description": "CLI tool for monitoring Austrian RIS judgments related to cyberbullying and hate speech",
  "author": "urteil-watchdog",
  "license": "MIT",
  "keywords": [
    "austrian",
    "ris",
    "judgment",
    "legal",
    "cyberbullying",
    "hate-speech"
  ],
  "bin": {
    "urteil-watch": "./bin/urteil-watch.js"
  },
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cheerio": "^1.0.0-rc.12",
    "commander": "^11.1.0",
    "openai": "^4.24.1",
    "better-sqlite3": "^9.2.2",
    "js-yaml": "^4.1.0",
    "date-fns": "^3.0.6",
    "crypto-js": "^4.2.0",
    "exponential-backoff": "^3.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/chai": "^4.3.11",
    "@types/commander": "^2.12.2",
    "@types/crypto-js": "^4.2.1",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.5",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "tsx": "^4.6.2",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vite-tsconfig-paths": "^4.2.2",
    "vitest": "^1.1.0"
  }
}
